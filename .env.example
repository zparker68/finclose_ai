# FinClose AI — Environment Variables
# Copy to .env and fill in values
# Never commit .env to git

# LLM model name (Ollama model tag)
# Options: mistral, llama3.2:3b, qwen2.5:7b, deepseek-r1:7b
FINCLOSE_MODEL=llama3.2:3b

# Database path (default: finclose_data_gen/finclose.db)
# FINCLOSE_DB=/absolute/path/to/finclose.db

# Ollama base URL
# OLLAMA_BASE_URL=http://localhost:11434

# API Authentication
# FINCLOSE_USER=admin
# FINCLOSE_PASSWORD=finclose2024
# FINCLOSE_JWT_SECRET=change-this-to-a-random-secret-in-production

# LangSmith Telemetry (optional — enables real-time agent trace visualization)
# Sign up free at https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key
# LANGCHAIN_PROJECT=finclose-ai
